# MSaaS local development defaults

MONGODB_URI=mongodb://localhost:27017/msaas
SPRING_MONGODB_URI=mongodb://localhost:27017/msaas
REDIS_URI=redis://localhost:6379

JWT_SECRET=replace-this-development-secret-with-at-least-32-bytes
APP_PUBLIC_BASE_URL=http://localhost:8081
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
ADMIN_BOOTSTRAP_EMAIL=admin@example.com

# EMBEDDED runs control API and runtime in one JVM.
# CONTROL runs the public API/gateway.
# RUNTIME runs an internal worker.
APP_RUNTIME_ROLE=EMBEDDED
APP_RUNTIME_BASE_URL=http://localhost:8082
APP_RUNTIME_INTERNAL_SECRET=local-runtime-secret

# UI build arg used by ui/Dockerfile and local Vite builds.
VITE_API_BASE_URL=http://localhost:8081
